{
	"name": "jonasleonhard.de",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "CURRENT_GIT_HASH=$(git rev-parse HEAD) vite dev",
		"build": "CURRENT_GIT_HASH=$(git rev-parse HEAD) vite build && bun run postbuild",
		"postbuild": "pagefind --site build; rm -r static/pagefind; cp -r build/pagefind static/pagefind",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/postcss": "^4.3.1",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "^1.3.14",
		"@types/eslint": "^9.6.1",
		"bits-ui": "^2.18.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"lucide-svelte": "^1.0.1",
		"mode-watcher": "^1.1.0",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shiki": "^4.2.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-inview": "^4.0.4",
		"svelte-sonner": "^1.1.1",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vaul-svelte": "^0.3.2",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@arisbh/marqueeck": "^0.5.1",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.21.0",
		"gsap": "^3.15.0",
		"svelte-portal": "^2.2.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"three": "^0.184.0"
	}
}
